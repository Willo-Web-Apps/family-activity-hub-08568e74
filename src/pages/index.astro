---
import Base from '../layouts/Base.astro';
---

<Base
  title="Rallyday — Every activity, every kid, one place."
  description="Rallyday unifies every kid's sports, activities, and school events into one beautiful family hub your whole household will actually use."
>

  <!-- ================================================================
       HERO — Immersive, warm gradient, community feeling
       ================================================================ -->
  <section class="rallyday-hero relative overflow-hidden min-h-[90vh] flex items-center">

    <!-- Layered warm gradient background -->
    <div class="absolute inset-0" style="
      background:
        radial-gradient(ellipse 80% 60% at 15% 20%,  oklch(0.67 0.16 40  / 0.18) 0%, transparent 70%),
        radial-gradient(ellipse 65% 55% at 85% 75%,  oklch(0.42 0.09 230 / 0.14) 0%, transparent 65%),
        radial-gradient(ellipse 50% 40% at 60% 10%,  oklch(0.67 0.16 40  / 0.09) 0%, transparent 60%),
        linear-gradient(165deg, oklch(0.99 0.008 65) 0%, oklch(0.97 0.014 55) 55%, oklch(0.95 0.016 50) 100%);
    "></div>

    <!-- Noise texture overlay -->
    <div class="absolute inset-0 pointer-events-none" style="
      background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.72' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E\");
      opacity: 0.025;
      mix-blend-mode: overlay;
    "></div>

    <!-- Decorative dot-grid, top right -->
    <div class="absolute top-16 right-0 w-80 h-80 opacity-30 pointer-events-none" style="
      background-image: radial-gradient(circle at 1.5px 1.5px, oklch(0.42 0.09 230 / 0.25) 1.5px, transparent 0);
      background-size: 22px 22px;
      mask-image: radial-gradient(ellipse 70% 70% at 80% 20%, black 30%, transparent 80%);
    "></div>

    <div class="relative z-10 max-w-6xl mx-auto px-5 sm:px-8 lg:px-10 py-24 lg:py-32">
      <div class="max-w-3xl">

        <!-- Pre-headline chip -->
        <div class="animate-fade-in inline-flex items-center gap-2 bg-white/70 backdrop-blur-sm border border-accent-200 rounded-full px-4 py-1.5 mb-8 shadow-sm">
          <span class="w-2 h-2 rounded-full bg-accent-500 animate-float"></span>
          <span class="text-sm font-semibold font-body text-surface-900" style="letter-spacing: 0.02em;">The family command center is here</span>
        </div>

        <!-- Main headline — IBM Plex Serif for warmth -->
        <h1 class="animate-slide-up font-display text-5xl sm:text-6xl lg:text-7xl font-700 leading-[1.08] tracking-tight text-surface-900">
          Stop Juggling<br/>
          <span style="color: oklch(0.42 0.09 230);">Five Apps.</span>
          <span class="block mt-1">Rally Your Family</span>
          <em class="not-italic" style="color: oklch(0.67 0.16 40);">in One.</em>
        </h1>

        <p class="animate-slide-up delay-200 mt-7 text-lg sm:text-xl font-body leading-relaxed max-w-xl" style="color: oklch(0.38 0.025 230);">
          Rallyday unifies every kid's sports, activities, and school events into one beautiful family hub your whole household will actually use.
        </p>

        <!-- CTAs -->
        <div class="animate-slide-up delay-300 mt-10 flex flex-col sm:flex-row gap-4 items-start">
          <a href="#join"
            class="inline-flex items-center gap-2 px-8 py-4 font-body font-semibold text-white rounded-2xl shadow-lg transition-all duration-200 hover:shadow-xl hover:-translate-y-0.5 text-base"
            style="background: oklch(0.67 0.16 40); box-shadow: 0 4px 20px oklch(0.67 0.16 40 / 0.35);">
            Get early access — it's free
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
          </a>
          <a href="#how-it-works" class="inline-flex items-center gap-2 px-6 py-4 font-body font-medium rounded-2xl border transition-all duration-200 text-base"
            style="color: oklch(0.42 0.09 230); border-color: oklch(0.42 0.09 230 / 0.3); background: white/60;">
            See how it works
          </a>
        </div>

        <!-- Social proof micro-row -->
        <div class="animate-slide-up delay-400 mt-10 flex flex-wrap items-center gap-5 text-sm font-body" style="color: oklch(0.45 0.025 230);">
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4" style="color: oklch(0.67 0.16 40);" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 0 0 .95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 0 0-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 0 0-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 0 0-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 0 0 .951-.69l1.07-3.292Z"/></svg>
            4.9/5 from early families
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4" style="color: oklch(0.67 0.16 40);" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z"/></svg>
            2,400+ families on waitlist
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4" style="color: oklch(0.67 0.16 40);" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
            No credit card required
          </span>
        </div>
      </div>
    </div>

    <!-- Wave divider -->
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 56" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full" preserveAspectRatio="none" style="height:56px;">
        <path d="M0 56 L0 28 C240 0 480 56 720 28 C960 0 1200 56 1440 28 L1440 56 Z" fill="oklch(0.985 0.008 65)"/>
      </svg>
    </div>
  </section>


  <!-- ================================================================
       IMPACT STATS — Big numbers in warm orange cards
       ================================================================ -->
  <section class="py-16 lg:py-20" style="background: oklch(0.985 0.008 65);">
    <div class="max-w-5xl mx-auto px-5 sm:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
        {[
          { number: "6 apps", label: "replaced by Rallyday", sub: "avg. family uses" },
          { number: "4 hrs", label: "saved per week", sub: "per primary scheduler" },
          { number: "2,400+", label: "families on waitlist", sub: "and counting" },
          { number: "100%", label: "whole family onboard", sub: "even the reluctant ones" },
        ].map((stat, i) => (
          <div
            class={`rounded-2xl p-6 lg:p-8 text-center animate-slide-up`}
            style={`animation-delay: ${i * 0.1}s; background: ${i % 2 === 0 ? 'oklch(0.67 0.16 40)' : 'oklch(0.42 0.09 230)'}; color: white;`}
          >
            <div class="font-display text-3xl lg:text-4xl font-700 leading-none tracking-tight">{stat.number}</div>
            <div class="mt-2 text-sm font-body font-600 leading-tight opacity-100">{stat.label}</div>
            <div class="mt-1 text-xs font-body opacity-75">{stat.sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ================================================================
       PROBLEM — The mental load story
       ================================================================ -->
  <section class="py-20 lg:py-28" style="background: white;">
    <div class="max-w-5xl mx-auto px-5 sm:px-8">
      <div class="grid lg:grid-cols-2 gap-14 lg:gap-20 items-center">

        <!-- Left: Story -->
        <div>
          <p class="font-body font-semibold text-sm uppercase tracking-widest" style="color: oklch(0.67 0.16 40);">Sound familiar?</p>
          <h2 class="mt-4 font-display text-4xl lg:text-5xl font-700 leading-[1.1] text-surface-900">
            Four kids. Six apps. One exhausted parent.
          </h2>
          <p class="mt-6 font-body text-lg leading-relaxed" style="color: oklch(0.38 0.025 230);">
            TeamSnap for soccer. Remind for swim. A Google Sheet for carpool. Your husband's iCal. The school app. And somehow, you're still the only one who knows when Mia's recital is.
          </p>
          <p class="mt-4 font-body text-lg leading-relaxed" style="color: oklch(0.38 0.025 230);">
            The problem isn't that your family is busy — it's that no tool was ever built <em>for you</em>, the scheduler, the keeper of the whole family's chaos.
          </p>
          <p class="mt-4 font-body text-lg font-semibold" style="color: oklch(0.42 0.09 230);">
            Until Rallyday.
          </p>
        </div>

        <!-- Right: App cards stacked illustration -->
        <div class="relative flex justify-center items-center min-h-[320px]">
          <!-- Stacked "chaos" apps before Rallyday -->
          <div class="relative w-full max-w-sm">
            {[
              { name: "TeamSnap", color: "oklch(0.45 0.12 220)", top: "0px", left: "30px", rotate: "-4deg" },
              { name: "School App", color: "oklch(0.50 0.10 150)", top: "32px", left: "10px", rotate: "2deg" },
              { name: "Google Cal", color: "oklch(0.60 0.14 30)", top: "64px", left: "50px", rotate: "-2deg" },
              { name: "Remind", color: "oklch(0.45 0.10 260)", top: "96px", left: "20px", rotate: "3deg" },
              { name: "iCal", color: "oklch(0.50 0.07 210)", top: "128px", left: "40px", rotate: "-1deg" },
            ].map((app) => (
              <div
                class="absolute w-52 h-14 rounded-xl flex items-center px-5 gap-3 shadow-md font-body font-semibold text-white text-sm"
                style={`background: ${app.color}; top: ${app.top}; left: ${app.left}; transform: rotate(${app.rotate}); opacity: 0.75;`}
              >
                <svg class="w-5 h-5 opacity-80" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><path d="M12 18h.01"/></svg>
                {app.name}
              </div>
            ))}
            <!-- Arrow pointing down to Rallyday card -->
            <div class="absolute" style="top: 220px; left: 60px;">
              <svg class="w-8 h-8" style="color: oklch(0.67 0.16 40);" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </div>
            <!-- Rallyday unified card -->
            <div
              class="absolute w-64 rounded-2xl p-5 shadow-xl font-body text-white"
              style="top: 252px; left: 20px; background: linear-gradient(135deg, oklch(0.42 0.09 230), oklch(0.50 0.09 230)); border: 2px solid oklch(0.67 0.16 40 / 0.6);"
            >
              <div class="font-display font-700 text-lg">Rallyday</div>
              <div class="text-xs mt-1 opacity-80 font-body">All 4 kids · All activities · One view</div>
              <div class="mt-3 flex gap-2">
                {["⚽ Soccer", "🎸 Guitar", "🏊 Swim", "📚 Tutor"].map(tag => (
                  <span class="px-2 py-0.5 rounded-full text-xs font-semibold" style="background: oklch(0.67 0.16 40 / 0.9);">{tag}</span>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ================================================================
       HOW IT WORKS — 3 steps, id="how-it-works"
       ================================================================ -->
  <section id="how-it-works" class="py-20 lg:py-28" style="background: oklch(0.985 0.008 65);">
    <div class="max-w-5xl mx-auto px-5 sm:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <p class="font-body font-semibold text-sm uppercase tracking-widest" style="color: oklch(0.67 0.16 40);">How Rallyday works</p>
        <h2 class="mt-4 font-display text-4xl lg:text-5xl font-700 leading-[1.1] text-surface-900">Set up in under 5 minutes. Really.</h2>
        <p class="mt-5 font-body text-lg leading-relaxed" style="color: oklch(0.38 0.025 230);">No spreadsheets. No syncing headaches. Just your whole family, organized.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 lg:gap-10 relative">
        <!-- Connecting line (desktop only) -->
        <div class="hidden md:block absolute top-10 left-[calc(16.67%+1.5rem)] right-[calc(16.67%+1.5rem)] h-px" style="background: linear-gradient(90deg, oklch(0.67 0.16 40 / 0.5), oklch(0.42 0.09 230 / 0.5));"></div>

        {[
          {
            step: "01",
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" /></svg>`,
            title: "Add your family",
            body: "Create profiles for each child, invite your partner, and set who manages what. Takes 2 minutes.",
          },
          {
            step: "02",
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" /></svg>`,
            title: "Connect every activity",
            body: "Import schedules from TeamSnap, school portals, and more — or add practices manually in seconds.",
          },
          {
            step: "03",
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0" /></svg>`,
            title: "Everyone stays in sync",
            body: "The whole family gets reminders, carpool alerts, and schedule changes — no more \"Why didn't you tell me?\"",
          },
        ].map((item, i) => (
          <div class={`relative bg-white rounded-2xl p-8 shadow-sm border animate-slide-up`}
            style={`animation-delay: ${i * 0.12}s; border-color: oklch(0.93 0.014 65);`}
          >
            <div class="w-14 h-14 rounded-xl flex items-center justify-center mb-6" style="background: oklch(0.93 0.05 40); color: oklch(0.67 0.16 40);">
              <Fragment set:html={item.icon} />
            </div>
            <div class="font-display text-5xl font-700 leading-none mb-2 select-none" style="color: oklch(0.93 0.014 65);">{item.step}</div>
            <h3 class="font-display text-xl font-700 text-surface-900 mb-3">{item.title}</h3>
            <p class="font-body text-base leading-relaxed" style="color: oklch(0.42 0.025 230);">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ================================================================
       FEATURES — Benefit-focused alternating layout
       ================================================================ -->
  <section class="py-20 lg:py-28" style="background: white;">
    <div class="max-w-5xl mx-auto px-5 sm:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <p class="font-body font-semibold text-sm uppercase tracking-widest" style="color: oklch(0.67 0.16 40);">Built for real family life</p>
        <h2 class="mt-4 font-display text-4xl lg:text-5xl font-700 leading-[1.1] text-surface-900">Everything you need, nothing you don't.</h2>
      </div>

      <div class="space-y-10">
        {[
          {
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z" /></svg>`,
            title: "One calendar, every kid",
            desc: "Color-coded per child, per activity. See your whole week at a glance — soccer, swim, piano, and school events side by side without switching apps.",
            badge: "Family Calendar",
          },
          {
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" /></svg>`,
            title: "Carpool coordination, done",
            desc: "Set up recurring carpool groups, track who's driving today, and send one-tap notifications when you're on your way. No more \"Can you cover Thursday?\" texts.",
            badge: "Carpool",
          },
          {
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0" /></svg>`,
            title: "Smart reminders that actually help",
            desc: "\"Leave in 15 mins for Mia's practice\" — location-aware reminders account for drive time, so nobody's late because nobody remembered.",
            badge: "Reminders",
          },
          {
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" /></svg>`,
            title: "Whole-family view, not just yours",
            desc: "Invite your partner, grandparents, and even older kids. Everyone sees what they need to see — without you having to forward every update manually.",
            badge: "Family Sharing",
          },
        ].map((feat, i) => (
          <div class={`flex flex-col sm:flex-row gap-6 items-start p-7 rounded-2xl border transition-all duration-200 hover:shadow-md animate-slide-up`}
            style={`animation-delay: ${i * 0.08}s; border-color: oklch(0.93 0.014 65); background: oklch(0.985 0.008 65);`}
          >
            <div class="flex-shrink-0 w-14 h-14 rounded-xl flex items-center justify-center" style="background: oklch(0.93 0.05 40); color: oklch(0.57 0.16 40);">
              <Fragment set:html={feat.icon} />
            </div>
            <div>
              <div class="flex items-center gap-3 mb-2">
                <h3 class="font-display text-xl font-700 text-surface-900">{feat.title}</h3>
                <span class="px-2.5 py-0.5 rounded-full text-xs font-body font-semibold" style="background: oklch(0.42 0.09 230 / 0.1); color: oklch(0.42 0.09 230);">{feat.badge}</span>
              </div>
              <p class="font-body text-base leading-relaxed" style="color: oklch(0.42 0.025 230);">{feat.desc}</p>
            </div>
